{
  "name": "@yuenwinyun/openclaw-message-stream",
  "version": "0.1.6",
  "description": "Session message stream analysis plugin for OpenClaw",
  "scripts": {
    "smoke-check": "node scripts/smoke-check.cjs",
    "release:check": "pnpm run test:e2e",
    "release:publish": "node -e \"const { execSync } = require('node:child_process'); const otp = process.env.NPM_OTP ? ` --otp ${process.env.NPM_OTP}` : ''; execSync(`pnpm publish --access public --no-git-checks${otp}`, { stdio: 'inherit' })\"",
    "release": "pnpm run release:check && pnpm version patch && pnpm run release:publish",
    "openclaw:config": "node skills/openclaw-message-stream/scripts/generate-openclaw-config.mjs --output openclaw-message-stream.config.json",
    "openclaw:config:merge": "node scripts/openclaw-config.mjs --config openclaw.config.json --write",
    "openclaw:config:remove": "node scripts/openclaw-config.mjs --config openclaw.config.json --action remove --write",
    "test:e2e": "vitest run --config vitest.config.ts"
  },
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.4"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src/**/*.ts",
    "README.md",
    "tsconfig.json",
    "scripts/openclaw-config.mjs",
    "scripts/smoke-check.cjs",
    "scripts/*.js",
    "skills/**/*"
  ],
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
